<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── 網路 ──────────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── 生物辨識 / 攝影機 ─────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- ── 推播通知（Android 13+）──────────────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── 勿擾模式：CRITICAL 警報頻道 setBypassDnd(true) 需要此權限 ────── -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- ── Foreground Service ────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- ── 開機自動啟動 SecurityService ────────────────────────────────── -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ── CRITICAL 警報震動 ─────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- ── MQTT 背景 WAKE_LOCK ───────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── 區域網路 NSD（mDNS Gateway 探索）────────────────────────────── -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />

    <application
        android:name=".SmartHomeApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartHomeGuardian"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <!-- ── 主 Activity（Single-Activity 架構）──────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Firebase Cloud Messaging 推播接收服務 ─────────────────────── -->
        <service
            android:name=".service.SmartHomeFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ── 安全守護 Foreground Service ─────────────────────────────── -->
        <!--
            stopWithTask="false"：即使用戶從最近任務列表滑走 APP，Service 仍持續運行
            START_STICKY 確保系統終止後自動重啟
        -->
        <service
            android:name=".service.SecurityService"
            android:exported="false"
            android:foregroundServiceType="dataSync|connectedDevice"
            android:stopWithTask="false" />

        <!-- ── 通知快捷「確認」廣播接收器 ───────────────────────────────── -->
        <!--
            exported="false"：限制只有本 APP 可觸發此廣播，防止惡意 APP 偽造確認（OWASP M1）
        -->
        <receiver
            android:name=".service.AlertAcknowledgeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.smarthome.guardian.ACK_ALERT" />
            </intent-filter>
        </receiver>

        <!-- ── 開機自動重啟 SecurityService ────────────────────────────── -->
        <!--
            裝置重新開機後，RECEIVE_BOOT_COMPLETED 廣播觸發此 Receiver，
            自動啟動 SecurityService 恢復 24/7 監控。
            exported="false"：開機廣播為系統廣播，本 APP 自動接收，不需 exported=true
        -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Android 9+ 的快速開機事件 -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ── FCM 預設通知頻道（應與 CHANNEL_SECURITY 一致）─────────── -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="channel_security" />

        <!-- ── FileProvider（稽核日誌 CSV/PDF 匯出用）─────────────────── -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
