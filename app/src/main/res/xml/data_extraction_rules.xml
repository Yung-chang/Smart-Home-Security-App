<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ Data Extraction Rules（用於 Android Backup / D2D Transfer）。

    以下路徑的資料被排除於備份與裝置間傳輸（D2D）之外：
    - EncryptedSharedPreferences（含 JWT Token、FCM Token）
    - SQLCipher 加密資料庫（含稽核日誌、設備快取）
    - 任何以 AES 加密的自訂檔案

    理由（OWASP M2 — 不安全資料儲存）：
    加密資料的安全性依賴 Android Keystore 金鑰，金鑰無法在裝置間遷移。
    若允許備份加密資料，在新裝置上將無法解密，反而造成資料損毀或安全風險。
-->
<data-extraction-rules>

    <cloud-backup>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database"   path="." />
        <exclude domain="file"       path="." />
        <exclude domain="external"   path="." />
    </cloud-backup>

    <device-transfer>
        <exclude domain="sharedpref" path="." />
        <exclude domain="database"   path="." />
        <exclude domain="file"       path="." />
        <exclude domain="external"   path="." />
    </device-transfer>

</data-extraction-rules>
